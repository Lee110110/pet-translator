# AI宠物翻译官 - 环境变量配置
# 复制此文件为 .env 并填入实际值

# 应用配置
DEBUG=true

# 数据库 (开发用SQLite, 生产用MySQL)
DATABASE_URL=sqlite+aiosqlite:///./data/pet_translator.db
# DATABASE_URL=mysql+asyncmy://root:password@localhost:3306/pet_translator

# JWT认证
JWT_SECRET_KEY=dev-secret-key-change-in-production
JWT_EXPIRE_HOURS=72

# DeepSeek LLM API
LLM_API_KEY=your-deepseek-api-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# DeepSeek Vision API (V2)
VISION_API_KEY=your-deepseek-api-key
VISION_BASE_URL=https://api.deepseek.com/v1
VISION_MODEL=deepseek-chat

# 文件上传
UPLOAD_DIR=uploads